<script>
    document.addEventListener("DOMContentLoaded", function () {
        const bubbleContainer = document.createElement("div");
        bubbleContainer.classList.add("bubbles");
        document.body.appendChild(bubbleContainer);

        for (let i = 0; i < 20; i++) { // Génère 20 bulles
            let bubble = document.createElement("div");
            bubble.classList.add("bubble");

            // Position aléatoire
            bubble.style.left = Math.random() * 100 + "vw";
            bubble.style.width = bubble.style.height = Math.random() * 30 + 10 + "px"; // Taille aléatoire
            bubble.style.animationDuration = Math.random() * 5 + 5 + "s"; // Durée aléatoire pour l'effet naturel
            bubbleContainer.appendChild(bubble);
        }
    });
    </script>

 
